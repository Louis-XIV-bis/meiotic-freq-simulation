setwd("~/Documents/Stage_simu/Sln_sweep/tests/100site_1/plot/sumstats/windows/pi")
library(tidyverse)
rm(list=ls())
windows = seq(1,1000000,length.out=499)
## DATA EGR ######################################################################
data_pi_EGR_100_site_1 = read_csv("pi_EGR_100_site_1.csv",col_names = F)
mean = apply(data_pi_EGR_100_site_1, 2, mean)
## DATA EGR ######################################################################
data_pi_EGR_100_site_1 = read_csv("pi_EGR_100_site_1.csv",col_names = F)
## DATA EGR ######################################################################
data_pi_EGR_100site_1 = read_csv("pi_EGR_100site_1.csv",col_names = F)
mean = apply(data_pi_EGR_100site_1, 2, mean)
sd = apply(data_pi_EGR_100site_1, 2, sd)
ymin = mean-sd
ymax = mean+sd
pi_EGR_100site_1 = data.frame(windows,mean,ymin,ymax) %>%
add_column(submodel="EGR", .before=1)
pi_EGR_100site_1
rm(data_pi_EGR_100site_1)
## DATA 100GR ######################################################################
data_pi_100GR_100site_1 = read_csv("pi_100GR_100site_1.csv",col_names = F)
mean = apply(data_pi_100GR_100site_1, 2, mean)
sd = apply(data_pi_100GR_100site_1, 2, sd)
ymin = mean-sd
ymax = mean+sd
pi_100GR_100site_1 = data.frame(windows,mean,ymin,ymax) %>%
add_column(submodel="100GR", .before=1)
pi_100GR_100site_1
rm(data_pi_100GR_100site_1)
rm(mean,sd,ymin,ymax,windows)
pi_100site_1 = bind_rows(pi_EGR_100site_1,pi_100GR_100site_1) %>%
as_tibble()
pi_100site_1
rm(pi_EGR_100site_1,pi_100GR_100site_1)
pi = ggplot(pi_100site_1, aes(x = windows, y = mean, group=submodel, fill=submodel)) +
geom_ribbon(aes(ymin=ymin, ymax=ymax),alpha=0.2) +
geom_line(aes(color = factor(submodel))) +
labs(title="Mesure du pi le long du génome", #
x = "Position (base)",
y = "pi",
color="Sous-modèles étudiés",
fill="Sous-modèles étudiés",
linetype="Sous-modèles étudiés") +
theme_light()
ggsave("pi.pdf")
pi
