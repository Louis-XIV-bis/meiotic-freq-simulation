mean = apply(data_EGR_1site_s100_new, 2, mean)
sd = apply(data_EGR_1site_s100_new, 2, sd)
ymin = mean-sd
ymax = mean+sd
EGR_1site_s100_new = data.frame(freq,mean,ymin,ymax) %>%
add_column(submodel="EGR", .before=1)
EGR_1site_s100_new
rm(data_EGR_1site_s100_new)
data_100GR_1site_s100_new = read_csv("rawSFS_100GR_1site_s100_new.csv",col_names = F)
mean = apply(data_100GR_1site_s100_new, 2, mean)
sd = apply(data_100GR_1site_s100_new, 2, sd)
ymin = mean-sd
ymax = mean+sd
r100GR_1site_s100_new = data.frame(freq,mean,ymin,ymax) %>%
add_column(submodel="100GR", .before=1)
r100GR_1site_s100_new
rm(data_100GR_1site_s100_new)
rm(mean,sd,ymin,ymax,freq)
raw_SFS_data = bind_rows(EGR_1site_s100_new,r100GR_1site_s100_new) %>%
as_tibble()
