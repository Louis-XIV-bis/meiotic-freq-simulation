library(tidyverse)
library(RColorBrewer)
setwd("/home/lollivier/Documents/Stage_simu/Simulations/neutral_model/LowRecomb/src/plot_script") # ENSUITE ADD %RATE
rm(list=ls())
TechStats = read_csv("/home/lollivier/Documents/Stage_simu/Simulations/neutral_model/LowRecomb/results/Technical_stats_Neutral_LowRecomb_50.csv") %>% #REPID = Neutral_EveryGenRecomb par ex
as_tibble() %>%
column_to_rownames(var="ID")
TechStats$CPUtime = TechStats$CPUtime/3600 # from seconds to hours
TechStats$MemoryUsage = TechStats$MemoryUsage/1e+9 # from bytes to gigabytes
TechStats %>%
ggplot(aes(x=factor(ID), y=CPUtime)) +
geom_boxplot() +
geom_jitter(color="black", size=0.2, alpha=0.9) +
labs(title = "Temps de calcul (en heures) pour le modèle : Neutral_LowRecomb", #####
x = "Neutral_LowRecomb",
y = "Temps de calcul (en heures de CPU)") +
scale_fill_brewer(palette="Dark2") +
ggsave("/home/lollivier/Documents/Stage_simu/Simulations/neutral_model/LowRecomb/plot/CPUtime_Neutral_LowRecomb_50.pdf")
TechStats = read_csv("/home/lollivier/Documents/Stage_simu/Simulations/neutral_model/LowRecomb/results/Technical_stats_Neutral_LowRecomb_50.csv") %>% #REPID = Neutral_EveryGenRecomb par ex
as_tibble() %>%
column_to_rownames(var="ID")
TechStats$CPUtime = TechStats$CPUtime/3600 # from seconds to hours
TechStats$MemoryUsage = TechStats$MemoryUsage/1e+9 # from bytes to gigabytes
TechStats
TechStats %>%
ggplot(aes(x=factor(RF), y=CPUtime)) +
geom_boxplot() +
geom_jitter(color="black", size=0.2, alpha=0.9) +
labs(title = "Temps de calcul (en heures) pour le modèle : Neutral_LowRecomb", #####
x = "Neutral_LowRecomb",
y = "Temps de calcul (en heures de CPU)") +
scale_fill_brewer(palette="Dark2") +
ggsave("/home/lollivier/Documents/Stage_simu/Simulations/neutral_model/LowRecomb/plot/CPUtime_Neutral_LowRecomb_50.pdf")
TechStats %>%
ggplot(aes(x=factor(RF), y=MemoryUsage)) +
geom_boxplot() +
geom_jitter(color="black", size=0.2, alpha=0.9) +
labs(title = "Consommation de la mémoire (en Mb) selon le facteur de mise à l'échelle",
x = "Neutral_LowRecomb",
y = "Usage de la mémoire (en Gb)") +
scale_fill_brewer(palette="Dark2") +
#scale_y_log10() +
ggsave("/home/lollivier/Documents/Stage_simu/Simulations/neutral_model/LowRecomb/plot/MemoryUsage_Neutral_LowRecomb_50.pdf")
TechStats %>%
ggplot(aes(x=factor(RF), y=MemoryUsage)) +
geom_boxplot() +
geom_jitter(color="black", size=0.2, alpha=0.9) +
theme(axis.text.x = element_blank()) +
labs(title = "Consommation de la mémoire (en Mb) selon le facteur de mise à l'échelle",
x = "Neutral_LowRecomb",
y = "Usage de la mémoire (en Gb)") +
scale_fill_brewer(palette="Dark2") +
#scale_y_log10() +
ggsave("/home/lollivier/Documents/Stage_simu/Simulations/neutral_model/LowRecomb/plot/MemoryUsage_Neutral_LowRecomb_50.pdf")
q()
