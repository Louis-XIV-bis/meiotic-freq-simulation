mean = apply(data_D_EGR_100site_1, 2, mean)
sd = apply(data_D_EGR_100site_1, 2, sd)
ymin = mean-sd
ymax = mean+sd
D_EGR_100site_1 = data.frame(windows,mean,ymin,ymax) %>%
add_column(submodel="EGR", .before=1)
D_EGR_100site_1
rm(data_D_EGR_100site_1)
## DATA 100GR ######################################################################
data_D_100GR_100site_1 = read_csv("D_100GR_100site_1.csv",col_names = F)
mean = apply(data_D_100GR_100site_1, 2, mean)
sd = apply(data_D_100GR_100site_1, 2, sd)
ymin = mean-sd
ymax = mean+sd
D_100GR_100site_1 = data.frame(windows,mean,ymin,ymax) %>%
add_column(submodel="100GR", .before=1)
D_100GR_100site_1
rm(data_D_100GR_100site_1)
rm(mean,sd,ymin,ymax,windows)
D_100site_1 = bind_rows(D_EGR_100site_1,D_100GR_100site_1) %>%
as_tibble()
D_100site_1
rm(D_EGR_100site_1,D_100GR_100site_1)
D = ggplot(D_100site_1, aes(x = windows, y = mean, group=submodel, fill=submodel)) +
geom_ribbon(aes(ymin=ymin, ymax=ymax),alpha=0.2) +
geom_line(aes(color = factor(submodel))) +
labs(title="Mesure du D de Tajima le long du génome", #
